{
  "name": "agent-w",
  "version": "0.4.0",
  "description": "Agent W - Tools and skills for Model W projects with coding agents",
  "author": {
    "name": "with-madrid.com",
    "url": "https://github.com/ModelW/agent-w"
  },
  "skills": "./skills",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if [ ! -e .claude/skills ]; then mkdir -p .claude && ln -sfn ../.agents/skills .claude/skills; fi"
          }
        ]
      }
    ]
  }
}
